---
// Footer.astro
---

<footer id="contacto" class="relative bg-white/[0.01] border-t border-white/5 pt-20 pb-10 overflow-hidden">
  
  <!-- Ambient background glow -->
  <div class="absolute bottom-0 right-1/4 w-[600px] h-[600px] bg-brand-electric/5 rounded-full blur-[120px] -z-10 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Top Part: Contact / Newsletter -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 pb-16 border-b border-white/5 items-start">
      
      <!-- Contact Details -->
      <div class="lg:col-span-5 space-y-6">
        <a href="#inicio" class="flex items-center gap-3 group">
          <img
            src="/Picsart_26-06-08_19-14-58-865.webp"
            alt="merco logo"
            class="h-10 w-auto rounded-xl object-contain shadow-lg group-hover:scale-105 transition-transform duration-200"
          />
        </a>
        
        <p class="text-gray-400 text-sm md:text-base leading-relaxed font-light">
          Revolucionando el e-commerce multirrubro con agentes cognitivos integrados por WhatsApp. Automatiza tus ventas hoy mismo.
        </p>

        <div class="space-y-3 pt-2">
          <div class="flex items-center gap-3 text-sm text-gray-300">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-brand-indigo">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
            <span>contacto@merco.com</span>
          </div>
          <div class="flex items-center gap-3 text-sm text-gray-300">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-brand-blue">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25s-7.5-4.108-7.5-11.25a7.5 7.5 0 1 1 15 0Z" />
            </svg>
            <span>Bogotá, Colombia</span>
          </div>
        </div>

        <!-- Brand Mascot Image in Footer -->
        <div class="pt-3 -mt-2 lg:pt-6 lg:mt-4 mb-4 lg:-mb-16 flex items-center justify-start relative z-10">
          <img 
            src="/Picsart_26-06-10_10-45-25-213-_1_.webp" 
            alt="Mascota de marca merco" 
            class="h-32 sm:h-44 lg:h-64 w-auto object-contain hover:scale-105 transition-transform duration-300 cursor-pointer" 
          />
        </div>
      </div>

      <!-- Contact Form -->
      <div class="lg:col-span-7 space-y-6">
        <h3 class="text-xl font-bold text-white">Envíanos un mensaje</h3>
        
        <form class="space-y-4" onsubmit="event.preventDefault(); alert('¡Mensaje enviado con éxito! Nos comunicaremos contigo a la brevedad.');">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-1">
              <label for="name" class="text-xs font-semibold text-gray-400 uppercase">Nombre</label>
              <input 
                type="text" 
                id="name" 
                placeholder="Juan Pérez" 
                required
                class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-brand-electric focus:ring-1 focus:ring-brand-electric transition-all"
              />
            </div>
            <div class="space-y-1">
              <label for="phone" class="text-xs font-semibold text-gray-400 uppercase">Teléfono</label>
              <input 
                type="tel" 
                id="phone" 
                placeholder="+57 300 123 4567" 
                required
                class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-brand-electric focus:ring-1 focus:ring-brand-electric transition-all"
              />
            </div>
            <div class="sm:col-span-2 space-y-1">
              <label for="email" class="text-xs font-semibold text-gray-400 uppercase">Correo Electrónico</label>
              <input 
                type="email" 
                id="email" 
                placeholder="juan@correo.com" 
                required
                class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-brand-electric focus:ring-1 focus:ring-brand-electric transition-all"
              />
            </div>
          </div>
          <div class="space-y-1">
            <label for="message" class="text-xs font-semibold text-gray-400 uppercase">Mensaje</label>
            <textarea 
              id="message" 
              rows="4" 
              placeholder="Hola, me gustaría saber cómo puedo integrar el agente de IA..." 
              required
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-brand-electric focus:ring-1 focus:ring-brand-electric transition-all resize-none"
            ></textarea>
          </div>
          
          <button 
            type="submit" 
            class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3.5 rounded-xl btn-electric text-white text-sm font-semibold hover:scale-[1.01] active:scale-[0.99] transition-all cursor-pointer"
          >
            Enviar Mensaje
          </button>
        </form>
      </div>

    </div>

    <!-- Bottom Part: Copyright & Links -->
    <div class="pt-8 flex flex-col md:flex-row items-center justify-between gap-6">
      
      <!-- Links -->
      <div class="flex flex-wrap justify-center gap-6 text-sm text-gray-400">
        <a href="#inicio" class="hover:text-white transition-colors">Inicio</a>
        <a href="#caracteristicas" class="hover:text-white transition-colors">Características</a>
        <a href="#como-funciona" class="hover:text-white transition-colors">Cómo Funciona</a>
        <a href="#integraciones" class="hover:text-white transition-colors">Integraciones</a>
        <a href="#" class="hover:text-white transition-colors">Políticas de Privacidad</a>
      </div>

      <!-- Copyright -->
      <p class="text-xs text-gray-500">
        &copy; {new Date().getFullYear()} merco. Todos los derechos reservados.
      </p>

    </div>

  </div>
</footer>

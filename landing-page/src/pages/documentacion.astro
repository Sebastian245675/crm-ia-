---

<DocLayout 
  title="Documentación de la Tienda merco | Manuales de Usuario" 
  description="Biblioteca completa de documentación de merco. Manuales técnicos del POS, sincronización de variantes y configuración del bot conversacional de WhatsApp."
  currentPath="/documentacion"
>
  <div class="space-y-8 max-w-full">
    
    <!-- Header Section -->
    <div class="space-y-4">
      <h1 class="text-3xl sm:text-4xl font-extrabold text-[#11103d] tracking-tight">
        Documentación merco
      </h1>
      <p class="text-slate-600 text-sm sm:text-base leading-relaxed max-w-3xl font-normal">
        Encuentra guías operativas, especificaciones técnicas y checklists para exprimir al máximo tu panel de administración, catálogo de productos y tu asistente de ventas autónomo de IA.
      </p>
    </div>

    <!-- Interactive Search Bar -->
    <div class="bg-slate-50 border border-slate-200/60 p-4 sm:p-5 rounded-2xl flex flex-col sm:flex-row sm:items-center justify-between gap-4 shadow-[0_4px_20px_rgba(0,0,0,0.01)]">
      <div class="relative flex-1 max-w-xl">
        <span class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </span>
        <input 
          type="text" 
          id="search-input"
          placeholder="Buscar guías (ej: WhatsApp, stock, Mercado Pago)..." 
          class="w-full bg-white border border-slate-200 rounded-xl py-2.5 pl-10 pr-10 text-sm placeholder-slate-400 text-slate-700 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition-all"
        />
        <button 
          id="clear-search" 
          class="absolute inset-y-0 right-0 pr-3 flex items-center text-slate-400 hover:text-slate-600 hidden"
          type="button"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      
      <div class="text-xs sm:text-sm text-slate-500 font-medium whitespace-nowrap self-center">
        <span id="search-count" class="text-blue-600 font-bold">{cards.length}</span> de <span class="font-semibold text-slate-700">{cards.length}</span> guías disponibles
      </div>
    </div>

    <!-- Empty State for Search -->
    <div id="no-results" class="hidden py-16 text-center bg-slate-50/50 border border-dashed border-slate-200 rounded-2xl">
      <div class="text-3xl mb-2">🔍</div>
      <h3 class="text-base font-bold text-slate-700">No se encontraron artículos</h3>
      <p class="text-slate-500 text-xs sm:text-sm mt-1">Intenta buscar con otros términos como 'POS', 'Gemini' o 'Variantes'.</p>
    </div>

    <!-- Grouped Sections -->
    <div id="categories-container" class="space-y-12">
      {categories.map((cat) => {
        const catCards = cards.filter(card => card.category === cat.id);
        return (
          <section id={`category-sec-${cat.id}`} class="category-section space-y-5">
            <div class="flex items-center gap-2 pb-2 border-b border-slate-100">
              <span class="text-xl select-none">{cat.icon}</span>
              <h2 class="text-lg sm:text-xl font-bold text-slate-800 tracking-tight">
                {cat.name}
              </h2>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              {catCards.map((card) => (
                <a 
                  href={card.href}
                  class="doc-card block bg-white border border-slate-100 hover:border-slate-200 rounded-xl p-5 shadow-[0_2px_8px_rgba(0,0,0,0.01)] hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 group"
                  data-title={card.title.toLowerCase()}
                  data-description={card.description.toLowerCase()}
                  data-tags={card.tags}
                >
                  <h3 class="text-sm sm:text-base font-bold text-slate-800 group-hover:text-blue-600 transition-colors mb-1">
                    {card.title}
                  </h3>
                  <p class="text-slate-500 text-xs sm:text-sm leading-relaxed font-normal">
                    {card.description}
                  </p>
                </a>
              ))}
            </div>
          </section>
        );
      })}
    </div>

  </div>
</DocLayout>

<script>
  // Client-side real-time interactive search filtering script
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const clearBtn = document.getElementById('clear-search') as HTMLButtonElement;
    const searchCountEl = document.getElementById('search-count') as HTMLElement;
    const noResultsDiv = document.getElementById('no-results') as HTMLElement;
    const cards = document.querySelectorAll('.doc-card');
    const sections = document.querySelectorAll('.category-section');

    if (!searchInput) return;

    searchInput.addEventListener('input', () => {
      const query = searchInput.value.trim().toLowerCase();
      
      // Toggle clear button visibility
      if (query.length > 0) {
        clearBtn.classList.remove('hidden');
      } else {
        clearBtn.classList.add('hidden');
      }

      let totalVisible = 0;

      // Filter each section's cards
      sections.forEach((section) => {
        const sectionCards = section.querySelectorAll('.doc-card');
        let visibleInSection = 0;

        sectionCards.forEach((cardEl) => {
          const card = cardEl as HTMLElement;
          const title = card.getAttribute('data-title') || '';
          const description = card.getAttribute('data-description') || '';
          const tags = card.getAttribute('data-tags') || '';

          // Match query in title, description, or tags
          const isMatch = title.includes(query) || 
                          description.includes(query) || 
                          tags.includes(query);

          if (isMatch) {
            card.classList.remove('hidden');
            card.classList.add('block');
            visibleInSection++;
            totalVisible++;
          } else {
            card.classList.remove('block');
            card.classList.add('hidden');
          }
        });

        // Toggle entire category section visibility
        if (visibleInSection > 0) {
          section.classList.remove('hidden');
          section.classList.add('block');
        } else {
          section.classList.remove('block');
          section.classList.add('hidden');
        }
      });

      // Update counter and toggle empty state
      searchCountEl.textContent = totalVisible.toString();
      if (totalVisible === 0) {
        noResultsDiv.classList.remove('hidden');
      } else {
        noResultsDiv.classList.add('hidden');
      }
    });

    // Clear search handler
    clearBtn.addEventListener('click', () => {
      searchInput.value = '';
      searchInput.dispatchEvent(new Event('input'));
      searchInput.focus();
    });
  });
</script>
